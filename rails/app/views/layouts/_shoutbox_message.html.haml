.shoutbox-message.mb-3{ id: dom_id(msg) }
  .d-flex.justify-content-between{style: "font-size: 0.70em;"}
    %strong{style: "color: #408cfd;"}
      = msg.user.username_or_email
    %small.text-muted= time_ago_in_words(msg.created_at)
  %small.shoutbox-text{style: "font-size: 0.75em;"}
    = msg.message

  - if user_is_admin?
    = button_to t('shoutbox_admin_delete_button'),
        shoutbox_message_path(msg),
        method: :delete,
        data: { turbo_confirm: t('shoutbox_admin_delete_button_confirm') },
        class: "btn btn-outline-danger btn-xs mt-1"
