- if Setting.enabled?(:banner_message_enabled)
  - visibility = Setting.string_for(:banner_message_visibility, default: 'all').to_s.strip
  - if (visibility == 'all') || (visibility == 'logged_in' && user_signed_in?) || (visibility == 'logged_out' && !user_signed_in?)
    - message_html = Setting.string_for(:banner_message_html).presence
    
    -# Cookie-Prüfung: Banner nur anzeigen, wenn nicht ausgeblendet
    - banner_dismissed_until = cookies[:banner_dismissed_until].to_i
    - if message_html && (banner_dismissed_until.zero? || banner_dismissed_until < Time.current.to_i)

      .alert.alert-warning.banner-message.mb-4.d-flex.align-items-center{ 
        role: "alert",
        data: { banner: "true" }
      }
        = message_html.html_safe

        %button.btn-close.ms-auto{
          type: "button",
          aria: { label: "Schließen" }
        }