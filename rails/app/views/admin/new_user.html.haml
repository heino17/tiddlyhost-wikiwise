%h2= t('admin.tab_users.new_user')

%div.card{ style: "margin: 0 auto; max-width: 800px;" }
  %div.card-body

    = form_with model: @user, url: admin_users_path, method: :post, data: { turbo: false } do |f|
    
      - if @user.errors.any?
        .alert.alert-danger
          %strong Fehler beim Speichern:
          %ul
            - @user.errors.full_messages.each do |msg|
              %li= msg
    
      .mb-3
        = f.label t('admin.tab_users.users_name')
        = f.text_field :name, class: "form-control"
    
      .mb-3
        = f.label t('admin.tab_users.users_email')
        = f.email_field :email, class: "form-control"
    
      .mb-3
        = f.label t('admin.tab_users.users_username')
        = f.text_field :username, class: "form-control"
    
      .mb-3
        = f.label :user_type_id, t('admin.tab_users.users_access_level')
        = f.select :user_type_id,
            UserType.all.map { |t| [t.name, t.id] },
            {}, class: "form-control"
    
      .d-flex.justify-content-between.align-items-center.mb-2
        %label.mb-0.mx-1
        = t('admin.tab_users.users_password')
        = f.password_field :password, id: "user_password", class: "form-control"
      
      .mb-3
        %label.mb-0
        = t('admin.tab_users.users_password_confirmation')
        = f.password_field :password_confirmation, id: "user_password_confirmation", class: "form-control"
    
        %br
        %button.btn.btn-sm.btn-secondary{ type: "button", data: { password_generator: true } }
          = t('admin.tab_users.users_password_generate')
      
        %div.mt-1{
          data: {
            password_strength: true,
            strength_texts: I18n.t("admin.password.strength").to_json
          }
        }
          = t('admin.tab_users.users_password_strength')
          %span{ data: { password_strength_value: true } } -
      
        %div.mt-1.fw-bold{ data: { password_plain: true } } <!-- Klartext-Passwort -->
    
      .d-flex.justify-content-between.align-items-center.mb-2
        = f.submit t('admin.tab_users.new_user'), class: "btn btn-primary"
      
        = link_to t('admin.tab_users.new_user_cancel'),
                admin_users_path,
                class: "btn btn-secondary"
    