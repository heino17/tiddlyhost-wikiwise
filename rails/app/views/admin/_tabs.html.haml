-# ============================================
-# DESKTOP-TABS
-# ============================================
%div.admin-tabs-desktop{ style: "margin-bottom: 2em;" }
  %ul.nav.nav-tabs
    = tab_link_to("📊 #{t('admin.tabs_header.stats')}", action: :index)
    = tab_link_to("📈 #{t('admin.tabs_header.charts')}", action: :charts)
    = tab_link_to("👥 #{t('admin.tabs_header.users')}", action: :users)
    = tab_link_to("🌐 #{t('admin.tabs_header.sites')}", action: :sites)
    - if Settings.tiddlyspot_enabled?
      = tab_link_to("🛰️ #{t('admin.tabs_header.tspot_sites')}", action: :tspot_sites, no_stub: '1')
    = tab_link_to("💾 #{t('admin.tabs_header.storage')}", action: :storage)
    = tab_link_to("⚙️ #{t('admin.tabs_header.settings')}", action: :settings)
    = tab_link_to("💬 #{t('admin.tabs_header.comments')}", action: :comments_list)
    = tab_link_to("📦 #{t('admin.tabs_header.etc')}", action: :etc)

-# ============================================
-# MOBILE STICKY-GRUPPE
-# ============================================
- sticky_variant = Setting.enabled?(:sticky_menu_enabled) ? "mobile-sticky-group--with-header" : "mobile-sticky-group--no-header"

%div.mobile-sticky-group{ class: sticky_variant }
  %div.mobile-main-tabs
    = render 'mobile_main_tabs_only'

  - if params[:action] == 'settings'
    %div.mobile-settings-tabs
      = render 'mobile_settings_tabs_only'

