.setting-row.mt-3
  %h6
    - if setting[:group] == 'locales'
      - loc = setting[:key].to_s.sub("locale_enabled_", "").to_sym
      = flag_emoji_for(loc)
      = " "

    = setting[:label]

    - if setting[:group] == 'locales'
      - loc = setting[:key].to_s.sub("locale_enabled_", "").to_sym
      - current_default = Setting.string_for(:default_locale, default: "en").to_sym

      - if loc == I18n.locale
        %span.badge.bg-info.ms-2
          = t('admin.locale_language_badge_current')

      - if loc == current_default
        %span.badge.bg-primary.ms-2
          = t('admin.locale_language_badge_default')

  %p.text-muted.small= setting[:description]

  - if setting[:type] == :boolean
    .form-check.form-switch
      = hidden_field_tag "settings[#{setting[:key]}]", "0"
      = check_box_tag "settings[#{setting[:key]}]", "1", setting[:current_value],
          class: "form-check-input",
          id: "setting_#{setting[:key]}"
      = label_tag "setting_#{setting[:key]}", t('admin.tab_settings.aktivate'), class: "form-check-label"

  - elsif setting[:type] == :integer
    .input-group.w-25
      = number_field_tag "settings[#{setting[:key]}]", 
                         setting[:current_value],
                         min: setting[:min] || 1,
                         max: setting[:max] || 100,
                         class: "form-control"

      .input-group-text
        = setting[:suffix].presence || t('admin.max_tags_per_site.suffix')

  - elsif setting[:type] == :text
    .trix-container.mb-3
      %trix-toolbar{ id: "toolbar_#{setting[:key]}" }
        .trix-button-row
          %button{ type: "button", 
                   class: "trix-button", 
                   "data-trix-attribute": "heading1", 
                   title: t('admin.banner_message_editor.heading1') }
            %span 🅗¹
          %button{ type: "button", 
                   class: "trix-button", 
                   "data-trix-attribute": "bold", 
                   title: t('admin.banner_message_editor.bold') }
            %span 🅱️
          %button{ type: "button", 
                   class: "trix-button", 
                   "data-trix-attribute": "italic", 
                   title: t('admin.banner_message_editor.italic') }
            %span 𝑰
          %button{ type: "button", 
                   class: "trix-button", 
                   "data-trix-attribute": "strike", 
                   title: t('admin.banner_message_editor.strikethrough') }
            %span S̶
          %button{ type: "button", 
                   class: "trix-button", 
                   "data-trix-action": "undo", 
                   title: t('admin.banner_message_editor.undo') }
            %span ⟲
          %button{ type: "button", 
                   class: "trix-button", 
                   "data-trix-action": "redo", 
                   title: t('admin.banner_message_editor.redo') }
            %span ⟳
  
      = hidden_field_tag "settings[#{setting[:key]}]", 
                         setting[:raw_value] || setting[:current_value], 
                         id: "settings_#{setting[:key]}_input"
      
      %trix-editor{ input: "settings_#{setting[:key]}_input",
                    toolbar: "toolbar_#{setting[:key]}",
                    class: "trix-content form-control border rounded p-3",
                    style: "min-height: 150px;" }
      
      = label_tag "settings_#{setting[:key]}_label", setting[:label], class: "form-label mt-2"

  - elsif setting[:type] == :select
    - options = setting[:options].map { |opt| [t("admin.#{setting[:key]}.#{opt}", default: opt.to_s.humanize), opt] }

    = select_tag "settings[#{setting[:key]}]",
                 options_for_select(options, setting[:raw_value] || setting[:current_value]),
                 class: "form-select w-auto"
