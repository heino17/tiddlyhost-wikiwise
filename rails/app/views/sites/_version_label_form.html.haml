-# haml-lint:disable InstanceVariables
= form_for(@attachment, as: :attachment, method: :patch,
  url: "/sites/#{@site.id}/version_label/#{@blob_id}") do |f|
  = render layout: 'field_wrapper' do
    = f.label :attachment_label do
      = I18n.t('site_view_save_history_pop_label_info')
      #{cosmetic_saved_version_checksum(@attachment)},
      = I18n.t('site_view_save_history_saved')
      #{nice_timestamp(@attachment.blob.created_at, brief: true)}:
    = f.text_field :attachment_label, class: 'form-control'
