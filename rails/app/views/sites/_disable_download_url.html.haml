= render layout: 'field_wrapper' do
  .form-check.enable-tooltips
    = f.check_box :disable_download_url, class: 'form-check-input'
    = f.label :disable_download_url, class: 'form-check-label' do
      = t('site_view_edit_wiki_advanced_settings_disable_public_download_url').html_safe

      = render 'popover_help',
        html_content: t('site_view_edit_wiki_advanced_settings_disable_public_download_url_tooltip').html_safe