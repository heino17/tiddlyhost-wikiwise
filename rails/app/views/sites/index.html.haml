- collab_sites = @sites.select { |s| s.respond_to?(:last_collab_saved_at) && s.last_collab_saved_at.present? }
- if collab_sites.any?
  - collab_sites.each do |s|
    .alert.alert-info.mx-2.mb-2{ style: "max-width: 1050px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center;" }
      %span
        💾
        = "\"#{s.name}\""
        = t('collaborate_last_saved_by', name: s.last_collab_saved_by)
        %span.local-time{ data: { utc: s.last_collab_saved_at.utc.iso8601 } }
          = l(s.last_collab_saved_at, format: :short)
      = button_to "✕", dismiss_collab_banner_site_path(s), method: :delete,
          form: { style: "margin:0;", data: { turbo: false } },
          style: "background:none; border:none; cursor:pointer; font-size:1.1rem; color: red;",
          title: t('collaborate_delete_banner')

:javascript
  document.addEventListener("DOMContentLoaded", function() {
    document.querySelectorAll('.local-time').forEach(function(el) {
      const utc = new Date(el.dataset.utc);
      el.textContent = utc.toLocaleString(undefined, {
        day: '2-digit',
        month: 'short',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      });
    });
  });

%h1= I18n.t('your_sites')

- if @sites.empty?
  %p= t('click_create_below')

- else
  - if current_user.has_hub_link?
    .th-text-deco-none.th-text-smaller.m-3.mt-2.pt-1
      = link_to_user_hub_with_count(current_user) # Hier nochmal pluralize prüfen (yours)

  .float-end.sites-menu-container.small{ style: "margin-top: -0.6rem;" }
    = render 'filter_and_sort', sites: @sites, list_mode: @list_mode, list_mode_next: @list_mode_next

  .ps-1.ms-2.mb-3.th-text-small
    - if @filtered_site_count == @site_count
      = pluralize(@site_count, t('sites')) + ","
    - else
      = t('showing_filtered_sites', filtered_count: @filtered_site_count, access: params[:access], total_count: pluralize(@site_count, t('sites')))
      = link_to(t('clear_filter'), sites_path(s: params[:s]), style: 'text-decoration: none;') + "."
    = t('storage_used', bytes: nice_byte_count_pretty(@total_storage_bytes)) # Oder kombiniere es

  -# 'list_view' or 'grid_view'
  = render "#{@list_mode}_view"

- if @list_mode == "list"
  %div.text-muted{ style: "max-width: 1050px; margin: 0 auto; font-size: 0.71rem; padding-left: 10px;" }
    = t( "admin.admin_tabs_tables_ctrl_hint" )
    
  %div.text-muted{ style: "max-width: 1050px; margin: 0 auto; margin-top: -21px;  font-size: 0.5rem;" }
    = '⁉️ '

.nice-buttons.mx-2.my-4.py-2
  = turbo_off_link_to new_site_path, class: 'btn me-3', title: t('create') do
    = bi_icon('plus-lg', style: "margin-right: 1px;")
    = t('create')

  = turbo_off_link_to '/hub?t=1', class: 'btn me-3', title: t('create_from_template') do
    = bi_icon('files')
    = t('create_from_template')

  - if Settings.tiddlyspot_enabled?
    = link_to({ controller: :tspot_sites, action: :claim_form },
      class: 'btn', title: t('claim_tiddlyspot_site')) do
      = bi_icon('flag')
      = t('claim_tiddlyspot_site')

  - if @filtered_site_count > 0
    = turbo_off_link_to({ controller: :sites, action: :download_all }.merge(params.permit(:q, :kind, :access, :s, :tags)),
      class: 'btn', title: t('download_all', count: pluralize(@filtered_site_count, t('site')))) do
      = bi_icon('file-earmark-zip')
      = t('download_all')